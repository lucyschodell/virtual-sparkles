# Option A: Path to your Google Cloud service account JSON file (local dev)
# GOOGLE_CREDS_PATH=/path/to/your-service-account.json

# Option B: Paste the entire JSON blob (for platforms like Render with no persistent disk)
# GOOGLE_CREDS_JSON={"type":"service_account","project_id":"...","private_key":"...",...}

# Google Sheet ID containing Quotes, Photos, Likes, Downloads tabs
# SHEET_ID=153am0Y29gzQWFhlpxHLIaxQiHXVDTRasST484d7DYpg

# Path to the Arial TTF font file (defaults to ARIAL.TTF in project root)
# FONT_PATH=/path/to/ARIAL.TTF

# Comma-separated allowlist of image hostnames (auto-populated from Photos sheet)
# Only set this if you need to allow additional hosts beyond what's in your sheet
# ALLOWED_IMAGE_HOSTS=images.unsplash.com,example.com
